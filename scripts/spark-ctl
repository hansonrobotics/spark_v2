#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
VENV_DIR="$PROJECT_DIR/venv"

create_venv() {
    if [ ! -d "$VENV_DIR" ]; then
        python3 -m venv "$VENV_DIR"
    fi
}

activate_venv() {
    create_venv
    # shellcheck source=/dev/null
    source "$VENV_DIR/bin/activate"
}

cmd_install() {
    activate_venv
    pip install --upgrade pip
    pip install -r "$PROJECT_DIR/requirements.txt"
}

cmd_install_dev() {
    activate_venv
    pip install --upgrade pip
    pip install -r "$PROJECT_DIR/requirements-dev.txt"
}

cmd_run() {
    exec "$PROJECT_DIR/run.sh"
}

cmd_test() {
    activate_venv
    python -m pytest "$PROJECT_DIR/tests" -q
}

cmd_status() {
    curl -sf "http://localhost:${SPARK_PORT:-8588}/api/status" || {
        echo "Live runtime is not reachable on http://localhost:${SPARK_PORT:-8588}"
        exit 1
    }
}

cmd_help() {
    cat <<'EOF'
Usage: spark-ctl <command>

Commands:
  install      Create/update venv and install runtime dependencies
  install-dev  Install runtime + test dependencies
  run          Start the live runtime via ./run.sh
  test         Run the local test suite
  status       Query the live runtime status endpoint
  help         Show this message
EOF
}

case "${1:-help}" in
    install) cmd_install ;;
    install-dev) cmd_install_dev ;;
    run) cmd_run ;;
    test) cmd_test ;;
    status) cmd_status ;;
    help|-h|--help) cmd_help ;;
    *)
        echo "Unknown command: $1" >&2
        cmd_help
        exit 1
        ;;
esac
